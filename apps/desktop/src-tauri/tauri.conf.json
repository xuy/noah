{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Noah",
  "version": "0.16.0",
  "identifier": "app.onnoah.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Noah — Your Trusted Support",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500,
        "backgroundColor": "#0f172a",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "playbooks/**/*"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/xuy/noah/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4QTY4NTRDN0M3RURFRkEKUldUNjNuNThUSVdteUowNFhHdU13T0pTUjVrNkF0UEMycG1pWlNRTXhWWXZvckwzenlMWFZQUzAK"
    }
  }
}
