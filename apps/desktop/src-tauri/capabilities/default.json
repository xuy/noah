{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit",
    "core:webview:allow-set-webview-zoom"
  ]
}
