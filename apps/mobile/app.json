{
  "expo": {
    "name": "Noah",
    "slug": "noah-mobile",
    "scheme": "noah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1729"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.onnoah.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Noah needs camera access to capture photos for analysis.",
        "NSPhotoLibraryUsageDescription": "Noah can analyze photos from your library."
      }
    },
    "android": {
      "package": "app.onnoah.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0f1729",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA"
      ],
      "usesCleartextTraffic": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Noah needs camera access to capture photos for analysis."
        }
      ],
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-web-browser",
      "expo-crypto"
    ]
  }
}
