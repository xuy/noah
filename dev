#!/usr/bin/env bash
# Noah development CLI — one script, all platforms.
#
# Usage:
#   ./dev              — run in dev mode (hot-reload)
#   ./dev build        — release build (binary only)
#   ./dev appimage     — build cross-distro AppImage (Linux only)
#   ./dev check        — run all CI checks (tsc + vitest + cargo check)
#   ./dev test         — run frontend tests only
#   ./dev release      — build + upload via scripts/release.mjs
#
# Environment variables (all optional):
#   ANTHROPIC_API_KEY       — Anthropic API key (or configure in-app)
#   NOAH_API_URL            — override API endpoint
#   NOAH_MODEL              — override model name
#   NOAH_TIMEOUT            — HTTP timeout in seconds
#   NOAH_APP_DIR            — override app data directory
#   NOAH_PLATFORM           — override platform context string
#   NOAH_MODE=learn         — enable knowledge-creation system prompt
#   NOAH_SECRETS='{"k":"v"}'  — pre-configure secrets (JSON)
#   NOAH_ANSWERS='{"k":"v"}'  — pre-configure text answers (JSON)
#   NOAH_CONTAINER          — override distrobox container name (default: noah-build)
#   NO_DISTROBOX=1          — skip distrobox and run natively

set -euo pipefail

ROOT="$(cd "$(dirname "$0")" && pwd -P)"
MODE="${1:-dev}"
shift 2>/dev/null || true  # consume mode arg, remaining args pass through

OS="$(uname -s)"

# ── Platform detection ──────────────────────────────────────────────

# Configuration
CONTAINER="${NOAH_CONTAINER:-noah-build}"

# On Linux, by default we try to use distrobox for builds.
# Set NO_DISTROBOX=1 to run directly on the host (requires pnpm/rust installed).
USE_DISTROBOX="${NO_DISTROBOX:+false}"
USE_DISTROBOX="${USE_DISTROBOX:-true}"

detect_linux_container() {
    local container="$1"
    if [[ "$USE_DISTROBOX" != "true" ]]; then
        return 1
    fi
    if ! command -v distrobox &>/dev/null; then
        return 1
    fi
    if ! distrobox list 2>/dev/null | awk -F'|' 'NR>1 {print $2}' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -qx "$container"; then
        return 1
    fi
    return 0
}

# Forward Noah env vars into distrobox
distrobox_env_args() {
    local args=()
    for var in ANTHROPIC_API_KEY NOAH_API_URL NOAH_MODEL NOAH_TIMEOUT \
               NOAH_APP_DIR NOAH_PLATFORM NOAH_MODE NOAH_SECRETS NOAH_ANSWERS; do
        if [[ -n "${!var:-}" ]]; then
            args+=(--env "${var}=${!var}")
        fi
    done
    echo "${args[@]}"
}

# ── macOS: find a free port for Vite ────────────────────────────────

find_free_port() {
    local port=1420
    while lsof -iTCP:"$port" -sTCP:LISTEN -t &>/dev/null; do
        echo "[dev] Port $port in use, trying next..." >&2
        port=$((port + 2))  # +2 because HMR uses port+1
    done
    echo "$port"
}

# ── Commands ────────────────────────────────────────────────────────

cmd_dev() {
    case "$OS" in
        Darwin)
            # Load API key if available
            if [[ -z "${ANTHROPIC_API_KEY:-}" && -f "$HOME/.secrets/claude.txt" ]]; then
                export ANTHROPIC_API_KEY="$(sed 's/^ANTHROPIC_API_KEY=//' "$HOME/.secrets/claude.txt")"
            fi
            local port
            port=$(find_free_port)
            if [[ "$port" -ne 1420 ]]; then
                echo "[dev] Using port $port (default 1420 was busy)"
            fi
            export VITE_PORT="$port"
            cd "$ROOT/apps/desktop"
            exec pnpm tauri dev --config "{\"build\":{\"devUrl\":\"http://localhost:$port\"}}"
            ;;
        Linux)
            if detect_linux_container "$CONTAINER"; then
                local env_args
                env_args=$(distrobox_env_args)
                echo "Launching Noah in dev mode (hot-reload) via distrobox [$CONTAINER]..."
                # shellcheck disable=SC2086
                exec distrobox enter "$CONTAINER" $env_args -- \
                    bash -c "cd '$ROOT/apps/desktop' && pnpm tauri dev"
            else
                echo "Launching Noah in dev mode (hot-reload) natively..."
                cd "$ROOT/apps/desktop"
                exec pnpm tauri dev
            fi
            ;;
        *)
            echo "ERROR: dev mode not supported on $OS from this script." >&2
            echo "  On Windows, use: cd apps/desktop && pnpm tauri dev" >&2
            exit 1
            ;;
    esac
}

cmd_build() {
    case "$OS" in
        Darwin)
            cd "$ROOT/apps/desktop"
            pnpm tauri build --no-bundle "$@"
            echo "Binary: $ROOT/target/release/itman-desktop"
            ;;
        Linux)
            if detect_linux_container "$CONTAINER"; then
                echo "Building Noah release binary via distrobox [$CONTAINER]..."
                distrobox enter "$CONTAINER" -- \
                    bash -c "cd '$ROOT/apps/desktop' && pnpm tauri build --no-bundle $* 2>&1"
            else
                echo "Building Noah release binary natively..."
                cd "$ROOT/apps/desktop"
                pnpm tauri build --no-bundle "$@"
            fi
            echo "Binary: $ROOT/target/release/itman-desktop"
            ;;
        *)
            echo "ERROR: Use build-windows.ps1 on Windows." >&2
            exit 1
            ;;
    esac
}

cmd_appimage() {
    if [[ "$OS" != "Linux" ]]; then
        echo "ERROR: appimage is Linux-only." >&2
        exit 1
    fi
    if detect_linux_container "$CONTAINER"; then
        echo "Building AppImage via distrobox [$CONTAINER]..."
        distrobox enter "$CONTAINER" -- \
            bash -c "source ~/.cargo/env 2>/dev/null || true; cd '$ROOT/apps/desktop' && \
                     rm -rf '$ROOT/target/release/bundle/appimage' && \
                     NO_STRIP=true pnpm tauri build --bundles appimage 2>&1"
    else
        echo "WARNING: Building AppImage natively. This may result in glibc compatibility issues."
        cd "$ROOT/apps/desktop"
        rm -rf "$ROOT/target/release/bundle/appimage"
        NO_STRIP=true pnpm tauri build --bundles appimage
    fi
    local appimage
    appimage=$(find "$ROOT/target/release/bundle/appimage" -name "*.AppImage" 2>/dev/null | head -1)
    if [[ -n "$appimage" ]]; then
        echo "AppImage: $appimage"
        echo "Size: $(du -h "$appimage" | cut -f1)"
    fi
}

cmd_check() {
    echo "── TypeScript ──"
    (cd "$ROOT/apps/desktop" && npx tsc --noEmit)

    echo "── Frontend tests ──"
    (cd "$ROOT/apps/desktop" && npx vitest run)

    echo "── Cargo check ──"
    case "$OS" in
        Darwin)
            (cd "$ROOT" && cargo check -p itman-desktop "$@")
            ;;
        Linux)
            if detect_linux_container "$CONTAINER"; then
                distrobox enter "$CONTAINER" -- \
                    bash -c "cd '$ROOT' && cargo check -p itman-desktop $*"
            else
                (cd "$ROOT" && cargo check -p itman-desktop "$@")
            fi
            ;;
        *)
            (cd "$ROOT" && cargo check -p itman-desktop "$@")
            ;;
    esac

    echo "── All checks passed ──"
}

cmd_test() {
    cd "$ROOT/apps/desktop"
    pnpm test "$@"
}

cmd_run() {
    case "$OS" in
        Darwin)
            exec "$ROOT/target/release/itman-desktop"
            ;;
        Linux)
            if detect_linux_container "$CONTAINER"; then
                local env_args
                env_args=$(distrobox_env_args)
                # shellcheck disable=SC2086
                exec distrobox enter "$CONTAINER" $env_args -- \
                    "$ROOT/target/release/itman-desktop"
            else
                exec "$ROOT/target/release/itman-desktop"
            fi
            ;;
        *)
            exec "$ROOT/target/release/itman-desktop.exe"
            ;;
    esac
}

cmd_release() {
    cd "$ROOT"
    node scripts/release.mjs "$@"
}

# ── Dispatch ────────────────────────────────────────────────────────

case "$MODE" in
    dev)      cmd_dev "$@" ;;
    build)    cmd_build "$@" ;;
    appimage) cmd_appimage ;;
    check)    cmd_check "$@" ;;
    test)     cmd_test "$@" ;;
    release)  cmd_release "$@" ;;
    run)      cmd_run ;;
    -h|--help|help)
        sed -n '2,/^$/{ s/^# \?//; p }' "$0"
        ;;
    *)
        echo "Unknown command: $MODE"
        echo "Usage: $0 [dev|build|appimage|check|test|release|run]"
        exit 1
        ;;
esac
